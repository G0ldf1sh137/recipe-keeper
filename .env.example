# Postgres connection string. Matches the default docker-compose.yml service —
# run `docker compose up -d` and this works with no changes.
DATABASE_URL=postgres://recipe_keeper:recipe_keeper@localhost:5432/recipe_keeper

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials).
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Claude API key (https://platform.claude.com) — used by the recipe-photo transcription feature.
ANTHROPIC_API_KEY=

# S3 bucket for recipe photo uploads (bucket must allow public GetObject — see README).
S3_BUCKET=recipe-keeper
S3_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe (https://dashboard.stripe.com) — self-serve $5/month subscriptions.
# STRIPE_PRICE_ID is the recurring Price ID for that plan. STRIPE_WEBHOOK_SECRET
# comes from the webhook endpoint (or `stripe listen` for local dev).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Base URL used to build Stripe Checkout/Billing Portal redirect URLs.
APP_URL=http://localhost:3000

# Optional — if set, /api/cron/delete-expired-polls only runs when the request
# carries `Authorization: Bearer $CRON_SECRET`. Vercel Cron attaches this
# header automatically when the env var of the same name is configured on the
# project; leave unset locally, it's not required for dev.
CRON_SECRET=
